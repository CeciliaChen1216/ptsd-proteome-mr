# =============================================================================
# .gitignore for ptsd-proteome-mr
# =============================================================================
# Anything sensitive, machine-specific, or too large to redistribute stays out
# of the repository. Curated small CSV / TSV results and the supplementary
# workbook are committed explicitly (they are opt-in via `git add`).
# =============================================================================


# -----------------------------------------------------------------------------
# 1. Local configuration (contains absolute paths + API keys)
# -----------------------------------------------------------------------------
R/00_config.R
00_config.R


# -----------------------------------------------------------------------------
# 2. GWAS / pQTL / eQTL summary statistics (never commit — controlled access
#    or too large; obtain from original sources per the manuscript)
# -----------------------------------------------------------------------------
*.vcf
*.vcf.gz
*.vcf.bgz
*.vcf.gz.tbi
*.sumstats
*.sumstats.gz
*.ma
*.ma.gz
*.txt.gz
*.tsv.gz
*.neff.gz
daner_*
eur_ptsd*
ANX_2026*
ukb-ppp*
ukbppp*


# -----------------------------------------------------------------------------
# 3. SMR / LDSC / coloc reference files (SMR eQTL / plink LD reference)
# -----------------------------------------------------------------------------
*.besd
*.esi
*.epi
*.bed
*.bim
*.fam
eur_w_ld_chr/
w_hm3.snplist
reference.custom.maf.*.txt.gz


# -----------------------------------------------------------------------------
# 4. Large binary intermediates (regenerable from scripts + summary inputs)
# -----------------------------------------------------------------------------
*.rds
*.RData
*.rda


# -----------------------------------------------------------------------------
# 5. Backup / older-version files (do not litter the repo)
# -----------------------------------------------------------------------------
*_OLD.*
*_backup.*
*_bak.*
*.orig
*_v0.*
*_v1_draft.*


# -----------------------------------------------------------------------------
# 6. R session, history, and project files
# -----------------------------------------------------------------------------
.Rhistory
.Rapp.history
.RData
.Ruserdata
*.Rproj
.Rproj.user/
renv/library/
renv/local/
renv/lock/
renv/python/
renv/staging/


# -----------------------------------------------------------------------------
# 7. IDE / editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~


# -----------------------------------------------------------------------------
# 8. OS-specific
# -----------------------------------------------------------------------------
# macOS
.DS_Store
._*
.Spotlight-V100
.Trashes
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
# Linux
.directory
.Trash-*


# -----------------------------------------------------------------------------
# 9. Logs / temp / build artifacts
# -----------------------------------------------------------------------------
*.log
*.tmp
*.temp
*.bak
*.cache
tmp/
temp/
scratch/


# -----------------------------------------------------------------------------
# 10. Large output figures (commit only final PDFs/PNGs referenced by the
#     manuscript, not exploration output)
# -----------------------------------------------------------------------------
# Uncomment if you keep exploratory plots out of the repo:
# figures/exploratory/
# figures/draft/


# -----------------------------------------------------------------------------
# 11. Anything explicitly quarantined for the current submission
# -----------------------------------------------------------------------------
_archive_exploratory_not_used/


# -----------------------------------------------------------------------------
# 12. Environment files that may contain secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key


# -----------------------------------------------------------------------------
# 13. Python side-tools (occasionally used for HPA/VCF preprocessing)
# -----------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/
.venv/
venv/
